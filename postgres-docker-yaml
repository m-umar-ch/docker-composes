services:
  db_ocs:
    image: postgres:16
    container_name: postgres
    environment:
      POSTGRES_USER: chaudhry
      POSTGRES_PASSWORD: Hello1122
      POSTGRES_DB: croc
    volumes:
      - ./postgres_ocs:/var/lib/postgresql/data
    ports:
      - "5433:5432"  # Host port 5433 → Container port 5432
    restart: always

volumes:
  postgres_ocs:

